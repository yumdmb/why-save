<Window x:Class="WhySave.App.AddContextWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Add Context" Height="520" Width="540"
        Icon="Assets/WhySave.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="400" MinWidth="420">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="{Binding Filename, StringFormat='Add context for {0}'}"
                       FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding Path}" Foreground="Gray" FontSize="11"
                       TextTrimming="CharacterEllipsis" Margin="0,0,0,18"/>

            <Label Content="Reason" Padding="0,0,0,2"/>
            <TextBox x:Name="ReasonTextBox"
                     Text="{Binding Reason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap"
                     AcceptsReturn="True" Height="80"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,14"/>

            <Label Content="Project" Padding="0,0,0,2"/>
            <ComboBox x:Name="ProjectComboBox"
                      IsEditable="True"
                      ItemsSource="{Binding RecentProjects}"
                      Text="{Binding Project, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Margin="0,0,0,14"/>

            <Label Content="Source URL" Padding="0,0,0,2"/>
            <TextBox x:Name="SourceUrlTextBox"
                     Text="{Binding SourceUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,14"/>

            <Label Content="Notes" Padding="0,0,0,2"/>
            <TextBox x:Name="NotesTextBox"
                     Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap"
                     AcceptsReturn="True" Height="80"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,14"/>

            <Label Content="Saved date" Padding="0,0,0,2"/>
            <DatePicker x:Name="SavedDatePicker"
                        SelectedDate="{Binding SavedDate, Mode=TwoWay}"
                        Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Command="{Binding CancelCommand}"
                        Padding="18,5" Margin="0,0,10,0" IsCancel="True"/>
                <Button x:Name="SaveButton"
                        Content="Save"
                        Click="SaveButton_Click"
                        Padding="18,5" IsDefault="True"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
