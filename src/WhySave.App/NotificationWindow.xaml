<Window x:Class="WhySave.App.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Why Save"
        Icon="Assets/WhySave.ico"
        Width="360"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize">
    <Border Margin="12"
            CornerRadius="10"
            Background="#FF1F2430"
            BorderBrush="#FF3A4150"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.45" Color="#FF000000"/>
        </Border.Effect>
        <Grid Margin="16,14,16,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Why did you save this?"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#FFF2F4F8"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        x:Name="CloseButton"
                        Content="&#x2715;"
                        Width="22"
                        Height="22"
                        Padding="0"
                        FontSize="11"
                        Foreground="#FF9AA4B2"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>
            </Grid>

            <TextBlock Grid.Row="1"
                       x:Name="FilenameText"
                       Margin="0,8,0,0"
                       FontSize="13"
                       Foreground="#FFC7CEDB"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"
                       ToolTipService.InitialShowDelay="300"/>

            <StackPanel Grid.Row="2"
                        Margin="0,14,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="LaterButton"
                        Content="Later"
                        MinWidth="72"
                        Height="30"
                        Margin="0,0,8,0"
                        Padding="12,0"
                        Foreground="#FFD7DCE5"
                        Background="#FF2B3140"
                        BorderBrush="#FF3A4150"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="LaterButton_Click"/>
                <Button x:Name="AddContextButton"
                        Content="Add Context"
                        MinWidth="104"
                        Height="30"
                        Padding="12,0"
                        Foreground="White"
                        Background="#FF3D7EFF"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="AddContextButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
