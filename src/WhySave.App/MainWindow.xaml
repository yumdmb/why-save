<Window x:Class="WhySave.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WhySave.App.ViewModels"
        mc:Ignorable="d"
        Title="Why Save" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Visibility="Hidden"
        Closing="Window_Closing">
    <Window.Resources>
        <DataTemplate x:Key="FileRowTemplate" DataType="{x:Type vm:FileRowViewModel}">
            <Border Padding="8,4" BorderThickness="0,0,0,1" BorderBrush="#FFE0E0E0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Filename}" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="{Binding SavedAtDisplay}" Foreground="Gray" FontSize="12"/>
                        <TextBlock Text="{Binding Project}" Foreground="DimGray" FontSize="11"
                                   Visibility="{Binding Project, Converter={StaticResource NullToVisibilityConverter}}"/>
                    </StackPanel>
                    <Border Grid.Column="1" Padding="6,2" Margin="8,0" CornerRadius="4"
                            Background="{Binding Status, Converter={StaticResource StatusToBrushConverter}}">
                        <TextBlock Text="{Binding StatusBadge}" FontSize="11" Foreground="White"/>
                    </Border>
                    <Button Grid.Column="2" Content="Add why"
                            Command="{Binding AddWhyCommand}" CommandParameter="{Binding}"
                            Visibility="{Binding CanAddWhy, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Padding="8,2" Margin="8,0,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="SearchResultTemplate" DataType="{x:Type vm:FileRowViewModel}">
            <Border Padding="8,6" BorderThickness="0,0,0,1" BorderBrush="#FFE0E0E0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Filename}" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="{Binding ReasonSnippet}" Foreground="DimGray" FontSize="12"
                                   TextTrimming="CharacterEllipsis" MaxWidth="480"
                                   Visibility="{Binding ReasonSnippet, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SavedAtDisplay}" Foreground="Gray" FontSize="11" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Project}" Foreground="DimGray" FontSize="11"
                                       Visibility="{Binding Project, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Padding="6,2" Margin="8,0" CornerRadius="4"
                            Background="{Binding Status, Converter={StaticResource StatusToBrushConverter}}">
                        <TextBlock Text="{Binding StatusBadge}" FontSize="11" Foreground="White"/>
                    </Border>
                    <Button Grid.Column="2" Content="Open"
                            Command="{Binding OpenCommand}" CommandParameter="{Binding}"
                            Visibility="{Binding CanOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Padding="10,2" Margin="8,0,0,0"/>
                    <Button Grid.Column="3" Content="Edit context"
                            Command="{Binding EditContextCommand}" CommandParameter="{Binding}"
                            Padding="10,2" Margin="4,0,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                    SelectionChanged="TabControl_SelectionChanged">
            <TabItem Header="Find">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" Text="{Binding Find.Query, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" Padding="6" Margin="0,0,0,8"
                             ToolTip="Find by filename, project, URL, reason, or notes"/>
                    <Button Grid.Row="1" Content="Find" Command="{Binding Find.SearchCommand}"
                            HorizontalAlignment="Left" Padding="16,4" Margin="0,0,0,8"/>
                    <Grid Grid.Row="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding Find.IsEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <ItemsControl ItemsSource="{Binding Find.Results}"
                                          ItemTemplate="{StaticResource SearchResultTemplate}"/>
                        </ScrollViewer>
                        <TextBlock Text="{Binding Find.EmptyMessage}"
                                   Foreground="Gray" FontStyle="Italic" FontSize="13"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding Find.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Inbox">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding Inbox.PendingCount, StringFormat='{}{0} files need context'}"
                               FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"
                               Visibility="{Binding Inbox.IsEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="{Binding Inbox.IsEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <Button Content="Dismiss to imported" Command="{Binding Inbox.DismissSelectedToLegacyCommand}" Margin="0,0,8,0" Padding="12,4"/>
                        <Button Content="Delete record" Command="{Binding Inbox.DeleteSelectedCommand}" Padding="12,4"/>
                    </StackPanel>
                    <ListView x:Name="InboxListView" Grid.Row="2" ItemsSource="{Binding Inbox.Items}"
                              SelectionMode="Extended"
                              ItemTemplate="{StaticResource FileRowTemplate}"
                              SelectionChanged="InboxListView_SelectionChanged"
                              BorderThickness="1" BorderBrush="#FFD0D0D0"
                              Visibility="{Binding Inbox.IsEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                    <TextBlock Grid.Row="2" Text="Your Memory Inbox is empty. New downloads will appear here."
                               Foreground="Gray" FontStyle="Italic" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding Inbox.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
