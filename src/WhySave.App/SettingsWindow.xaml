<Window x:Class="WhySave.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings" Height="400" Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Global Hotkey" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="Format: Ctrl+Win+Y, Alt+Shift+P, etc." Foreground="Gray" FontSize="11" Margin="0,0,0,4"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBox Text="{Binding HotKeyText, UpdateSourceTrigger=PropertyChanged}" Width="200" Padding="4" Margin="0,0,8,0"/>
            <Button Content="Apply" Command="{Binding ApplyHotKeyCommand}" Padding="12,4"/>
        </StackPanel>
        <TextBlock Grid.Row="3" Text="{Binding HotKeyStatus}" Foreground="Crimson" FontSize="11" Margin="0,0,0,16"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="4">
            <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" Margin="0,4"/>
            <CheckBox Content="Verbose logging" IsChecked="{Binding LogLevelVerbose}" Margin="0,4"/>
        </StackPanel>

        <Button Grid.Row="5" Content="Save" Command="{Binding SaveCommand}" HorizontalAlignment="Right" Padding="20,6"/>
    </Grid>
</Window>
