<Window x:Class="WhySave.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Settings" Height="680" Width="560"
        Icon="Assets/WhySave.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="560" MinWidth="480">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="Watched Folders" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
            <TextBlock Text="Folders monitored for new downloads. Changes apply immediately."
                       Foreground="Gray" FontSize="11" Margin="0,0,0,6"/>
            <ListBox x:Name="WatchedFoldersList" ItemsSource="{Binding WatchedFolders}" Height="100" Margin="0,0,0,4"
                     BorderThickness="1" BorderBrush="#FFD0D0D0"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="Add folder..." Command="{Binding AddWatchedFolderCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Remove selected" Command="{Binding RemoveWatchedFolderCommand}"
                        CommandParameter="{Binding SelectedItem, ElementName=WatchedFoldersList}"
                        Padding="12,4"/>
            </StackPanel>

            <TextBlock Text="Junk Rules" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
            <TextBlock Text="Glob patterns (one per line). Allow overrides block. Changes apply on Apply."
                       Foreground="Gray" FontSize="11" Margin="0,0,0,6"/>
            <Label Content="Block list" Padding="0,0,0,2"/>
            <TextBox Text="{Binding BlockGlobsText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" Height="80" VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="12" Margin="0,0,0,8"/>
            <Label Content="Allow list" Padding="0,0,0,2"/>
            <TextBox Text="{Binding AllowGlobsText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" Height="60" VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="12" Margin="0,0,0,8"/>
            <Label Content="Minimum file size (KB)" Padding="0,0,0,2"/>
            <Slider Minimum="0" Maximum="10240" TickFrequency="1" IsSnapToTickEnabled="True"
                    Value="{Binding MinSizeKB}" SmallChange="1" LargeChange="10" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding MinSizeKB, StringFormat='{}{0} KB'}" FontSize="11" Foreground="Gray" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="Apply junk rules" Command="{Binding SaveJunkRulesCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Reset to defaults" Command="{Binding ResetJunkRulesCommand}" Padding="12,4"/>
            </StackPanel>
            <TextBlock Text="{Binding JunkRulesStatus}" Foreground="DimGray" FontSize="11" Margin="0,0,0,16"/>

            <TextBlock Text="Global Hotkey" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
            <TextBlock Text="Format: Ctrl+Win+Y, Alt+Shift+P, etc." Foreground="Gray" FontSize="11" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBox Text="{Binding HotKeyText, UpdateSourceTrigger=PropertyChanged}" Width="200" Padding="4" Margin="0,0,8,0"/>
                <Button Content="Apply" Command="{Binding ApplyHotKeyCommand}" Padding="12,4"/>
            </StackPanel>
            <TextBlock Text="{Binding HotKeyStatus}" Foreground="Crimson" FontSize="11" Margin="0,0,0,16" TextWrapping="Wrap"/>

            <TextBlock Text="Encryption" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding EncryptionStatus}" Foreground="DimGray" FontSize="12" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="Rotate key" Command="{Binding RotateKeyCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Export data..." Command="{Binding ExportDataCommand}" Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="Clear all data" Command="{Binding ClearDataCommand}" Padding="12,4"/>
            </StackPanel>
            <TextBlock Text="{Binding RotateKeyStatus}" Foreground="DimGray" FontSize="11" Margin="0,0,0,16" TextWrapping="Wrap"/>

            <TextBlock Text="Updates &amp; Logging" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
            <CheckBox Content="Check for updates automatically (stable channel)"
                      IsChecked="{Binding AutoUpdateEnabled}" Margin="0,4"/>
            <CheckBox Content="Verbose logging (for watcher debugging)"
                      IsChecked="{Binding LogLevelVerbose}" Margin="0,4"/>
            <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}" Margin="0,4"/>

            <Button Content="Save" Command="{Binding SaveCommand}" HorizontalAlignment="Right"
                    Padding="20,6" Margin="0,16,0,0"/>

        </StackPanel>
    </ScrollViewer>
</Window>
