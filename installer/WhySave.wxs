<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX source for a per-user MSI installer.
  Installs to %LOCALAPPDATA%\Programs\WhySave\ with no UAC prompt.
  Writes the per-user HKCU Run registry entry for start-with-Windows.
  Build with: wix build WhySave.wxs -o WhySave.msi
  Requires WiX v4 (see build-msi.ps1 for the install command).
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package
    Name="Why Save"
    Manufacturer="Why Save"
    UpgradeCode="{3DE76B5D-E4DF-4F0D-A84E-DDEFAA977010}"
    Version="1.0.0"
    Language="1033"
    Codepage="1252"
    InstallerVersion="500">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Why Save is already installed." />
    <Media Id="1" Cabinet="WhySave.cab" EmbedCab="yes" />

    <Property Id="ApplicationFolderName" Value="WhySave" />
    <Property Id="WixAppFolder" Value="WixPerUserFolder" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Run Why Save" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WixShellExecTarget" Value="[#WhySaveExe]" />

    <Icon Id="AppIcon.ico" SourceFile="$(var.BuildDir)\WhySave.App.exe" />
    <CustomAction Id="LaunchApplication"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
                  DllEntry="WixShellExec"
                  Impersonate="yes" />

    <Feature Id="MainFeature" Title="Why Save" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="RegistryEntry" />
      <ComponentRef Id="ShortcutComponent" />
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="$(sys.SOURCEFILEDIR)License.rtf" />
    <UI>
      <Publish Dialog="ExitDialog"
               Control="Finish"
               Event="DoAction"
               Value="LaunchApplication"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="Why Save" />
    </StandardDirectory>
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="WhySave">
          <Component Id="ShortcutComponent" Guid="a1b2c3d4-0001-0000-0000-000000000001">
            <Shortcut Id="AppShortcut"
                      Name="Why Save"
                      Target="[INSTALLFOLDER]WhySave.App.exe"
                      Directory="AppMenuFolder"
                      WorkingDirectory="INSTALLFOLDER"
                      Icon="AppIcon.ico" />
            <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
            <RegistryValue Root="HKCU" Key="Software\WhySave" Name="Installed" Type="integer" Value="1" KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="AppFiles">
      <Component Id="MainExe" Guid="a1b2c3d4-0002-0000-0000-000000000002" Directory="INSTALLFOLDER">
        <File Id="WhySaveExe" Source="$(var.BuildDir)\WhySave.App.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Component Id="RegistryEntry" Guid="a1b2c3d4-0003-0000-0000-000000000003" Directory="INSTALLFOLDER">
      <RegistryValue Root="HKCU"
                     Key="Software\Microsoft\Windows\CurrentVersion\Run"
                     Name="WhySave"
                     Type="string"
                     Value="[INSTALLFOLDER]WhySave.App.exe"
                     KeyPath="yes" />
    </Component>
  </Fragment>

</Wix>
